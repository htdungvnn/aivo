# Docker ignore file for AIVO development containers

# Dependencies
node_modules
.pnpm-store
.npm

# Build outputs
dist
.wrangler
.next
out
build

# WASM packages (they'll be rebuilt inside container)
packages/*/pkg
!packages/aivo-compute/pkg/.gitkeep
!packages/infographic-generator/pkg/.gitkeep

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Testing
coverage
.nyc_output

# Misc
.cache
.turbo
.env
.env.local
.env.*.local
!.env/.env.example

# Docker
docker-compose.override.yml

# Mobile
apps/mobile/android
apps/mobile/ios
apps/mobile/.expo

# Database local files
packages/db/data
*.db
*.sqlite
