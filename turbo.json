{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env*.local", "**/tsconfig*.json"],
  "globalEnv": ["NODE_ENV", "CI", "TURBO_TELEMETRY_DISABLED"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        ".expo/**",
        "android/**/build/**",
        "ios/**/build/**",
        "pkg/**"
      ],
      "cache": true
    },
    "build:wasm": {
      "dependsOn": ["^build"],
      "outputs": ["pkg/**", "*.wasm", "target/**/release/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false,
      "dependsOn": []
    },
    "generate": {
      "cache": false,
      "persistent": false
    }
  }
}
