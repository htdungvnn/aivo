{
  "name": "@aivo/optimizer",
  "version": "0.1.0",
  "private": true,
  "description": "Content optimization for LLM token cost reduction - minification, semantic pruning, keyword extraction, and token counting",
  "main": "pkg/aivo_optimizer.js",
  "types": "pkg/aivo_optimizer.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/aivo_optimizer.d.ts",
      "import": "./pkg/aivo_optimizer.js",
      "require": "./pkg/aivo_optimizer.cjs"
    }
  },
  "scripts": {
    "build": "wasm-pack build --target worker --out-dir pkg",
    "build:nodejs": "wasm-pack build --target nodejs --out-dir pkg",
    "test": "cargo test",
    "clean": "rm -rf pkg target"
  },
  "files": ["pkg"],
  "keywords": ["wasm", "optimization", "llm", "tokens", "compression"],
  "author": "AIVO Team",
  "license": "MIT",
  "devDependencies": {
    "wasm-pack": "^0.14.0"
  }
}
