{
  "name": "@aivo/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for AIVO monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./user": {
      "types": "./dist/user.d.ts",
      "import": "./dist/user.js"
    },
    "./body": {
      "types": "./dist/body.d.ts",
      "import": "./dist/body.js"
    },
    "./workout": {
      "types": "./dist/workout.d.ts",
      "import": "./dist/workout.js"
    },
    "./nutrition": {
      "types": "./dist/nutrition.d.ts",
      "import": "./dist/nutrition.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js"
    },
    "./compute": {
      "types": "./dist/compute.d.ts",
      "import": "./dist/compute.js"
    },
    "./gamification": {
      "types": "./dist/gamification.d.ts",
      "import": "./dist/gamification.js"
    },
    "./social": {
      "types": "./dist/social.d.ts",
      "import": "./dist/social.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "import": "./dist/admin.js"
    },
    "./activity": {
      "types": "./dist/activity.d.ts",
      "import": "./dist/activity.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./calc": {
      "types": "./dist/calc.d.ts",
      "import": "./dist/calc.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "import": "./dist/content.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./files": {
      "types": "./dist/files.d.ts",
      "import": "./dist/files.js"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.js"
    },
    "./health": {
      "types": "./dist/health.d.ts",
      "import": "./dist/health.js"
    },
    "./live-workout": {
      "types": "./dist/live-workout.d.ts",
      "import": "./dist/live-workout.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.js"
    },
    "./notifications": {
      "types": "./dist/notifications.d.ts",
      "import": "./dist/notifications.js"
    },
    "./planning": {
      "types": "./dist/planning.d.ts",
      "import": "./dist/planning.js"
    },
    "./posture": {
      "types": "./dist/posture.d.ts",
      "import": "./dist/posture.js"
    },
    "./user-extended": {
      "types": "./dist/user-extended.d.ts",
      "import": "./dist/user-extended.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./voice": {
      "types": "./dist/voice.d.ts",
      "import": "./dist/voice.js"
    },
    "./biometric": {
      "types": "./dist/biometric.d.ts",
      "import": "./dist/biometric.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --build --force",
    "type-check": "tsc --noEmit",
    "test": "tsc --noEmit && echo 'Type check passed - shared types are valid'"
  },
  "dependencies": {},
  "devDependencies": {
    "@aivo/jest-config": "workspace:*",
    "typescript": "^6.0.3"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", {
        "useESM": true,
        "tsconfig": "<rootDir>/tsconfig.json"
      }]
    }
  }
}
