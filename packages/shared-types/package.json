{
  "name": "@aivo/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for AIVO monorepo",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build --force",
    "type-check": "tsc --noEmit",
    "test": "tsc --noEmit && echo 'Type check passed - shared types are valid'"
  },
  "dependencies": {},
  "devDependencies": {
    "@aivo/jest-config": "workspace:*",
    "typescript": "^6.0.3"
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", {
        "useESM": true,
        "tsconfig": "<rootDir>/tsconfig.json"
      }]
    }
  }
}
