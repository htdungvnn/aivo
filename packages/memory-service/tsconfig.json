{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@aivo/shared-types": ["../shared-types/dist"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "src/__tests__", "**/*.test.ts", "**/*.test.tsx"]
}
