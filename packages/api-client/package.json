  },
  "devDependencies": {
    "@aivo/jest-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^30.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^6.0.3"
  }
