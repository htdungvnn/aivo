{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@aivo/shared-types": ["../shared-types/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "drizzle", "src/__tests__/**", "**/*.test.ts", "seed-mock.ts"]
}
