{
  "name": "@aivo/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema and migrations for AIVO platform",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts"
    },
    "./migrations/*": "./drizzle/migrations/*"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate:local": "bunx wrangler d1 migrations apply aivo-db --local",
    "migrate:remote": "bunx wrangler d1 migrations apply aivo-db",
    "studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.40.0",
    "@cloudflare/d1": "^1.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.29.1",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  }
}
