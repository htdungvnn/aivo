{
  "name": "aivo",
  "version": "0.1.0",
  "private": true,
  "description": "AIVO - High-performance fitness web app and AI-native conversational platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "fetch": "pnpm install --force",
    "build:wasm": "pnpm --filter @aivo/compute run build",
    "build:compute": "pnpm --filter @aivo/compute run build",
    "test": "pnpm exec jest --config=jest.config.js --selectProjects api-unit,api-integration",
    "test:all": "jest",
    "test:unit": "jest --selectProjects=api-unit",
    "test:integration": "jest --selectProjects api-integration",
    "test:e2e": "pnpm --filter @aivo/web exec playwright test",
    "test:compute": "pnpm --filter @aivo/compute exec cargo test",
    "test:coverage": "turbo run test:coverage",
    "phase:complete": "bash scripts/phase-completion.sh",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo dist .wrangler",
    "clean:cache": "turbo run clean && pnpm store prune && rm -rf node_modules/.cache .turbo dist",
    "rebuild": "pnpm clean:cache && pnpm lint && pnpm fetch && pnpm build",
    "dev:tasks": "./scripts/tmux-dev.sh",
    "dev:parallel": "./scripts/parallel.sh",
    "deploy": "./scripts/deploy.sh",
    "deploy:quick": "./scripts/quick-deploy.sh",
    "deploy:local": "./scripts/deploy.sh --local",
    "migrate": "./scripts/migrate.sh",
    "migrate:remote": "./scripts/migrate.sh --remote",
    "health": "./scripts/health.sh",
    "dev:all": "./scripts/dev.sh",
    "setup": "./scripts/setup-dev.sh",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/node": "^22.13.5",
    "jose": "^6.2.2",
    "turbo": "^2.9.6",
    "typescript": "5.6.2",
    "wrangler": "^4.86.0"
  },
  "packageManager": "pnpm@10.33.0",
  "author": "AIVO Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "react-native-web": "^0.21.2",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.22.6",
      "babel-jest": "29.7.0",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver",
      "wasm-pack",
      "workerd"
    ]
  }
}
