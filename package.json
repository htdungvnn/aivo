{
  "name": "aivo",
  "version": "0.1.0",
  "private": true,
  "description": "AIVO - High-performance fitness web app and AI-native conversational platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "build:wasm": "pnpm --filter @aivo/compute run build && pnpm --filter @aivo/optimizer run build",
    "build:compute": "pnpm --filter @aivo/compute run build",
    "build:optimizer": "pnpm --filter @aivo/optimizer run build",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo dist .wrangler",
    "deploy": "./scripts/deploy.sh",
    "deploy:quick": "./scripts/quick-deploy.sh",
    "deploy:local": "./scripts/deploy.sh --local",
    "migrate": "./scripts/migrate.sh",
    "migrate:remote": "./scripts/migrate.sh --remote",
    "health": "./scripts/health.sh",
    "dev:all": "./scripts/dev.sh",
    "setup": "./scripts/setup-dev.sh"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/node": "^22.13.5",
    "jose": "^6.2.2",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.0",
  "author": "AIVO Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "zod": "^4.0.0"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.22.6",
      "babel-jest": "29.7.0",
      "metro": "0.81.5",
      "metro-core": "0.81.5",
      "metro-config": "0.81.5",
      "metro-babel-transformer": "0.81.5",
      "metro-resolver": "0.81.5",
      "metro-runtime": "0.81.5",
      "metro-source-map": "0.81.5",
      "metro-transform-plugins": "0.81.5",
      "metro-transform-worker": "0.81.5"
    }
  }
}
