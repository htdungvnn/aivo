# AIVO Web - Production Environment Variables for Cloudflare Pages
# Copy this file to .env.production.local before deploying

# OAuth Client IDs (required for authentication)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_FACEBOOK_CLIENT_ID=your-facebook-app-id

# API URL (production API endpoint)
NEXT_PUBLIC_API_URL=https://api.aivo.yourdomain.com

# R2 Public URL (for image storage - production)
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-bucket.r2.dev

# App URL (production domain)
NEXT_PUBLIC_APP_URL=https://aivo.yourdomain.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
