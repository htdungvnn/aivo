{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*"],
      "@aivo/shared-types": ["../../packages/shared-types/src"],
      "@aivo/compute": ["../../packages/aivo-compute/pkg"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "app/(tabs)/active-workout.tsx",
    "app/(tabs)/workouts.tsx",
    "app/(tabs)/insights.tsx",
    "app/components/biometric/**",
    "app/services/biometric-api.ts"
  ]
}
