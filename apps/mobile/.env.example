# ============================================================================
# MOBILE APP - EXPO ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# ============================================================================

# API Configuration
EXPO_PUBLIC_API_URL=https://api.aivo.website

# OAuth Client IDs (required for Google/Facebook login)
# Get these from:
# - Google: https://console.cloud.google.com/apis/credentials
# - Facebook: https://developers.facebook.com/apps
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
EXPO_PUBLIC_FACEBOOK_CLIENT_ID=your_facebook_client_id

# Optional: R2 Public URL for image storage
EXPO_PUBLIC_R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com/aivo-images

# Optional: App scheme for deep linking (default: aivo)
EXPO_PUBLIC_SCHEME=aivo
