{
  "name": "@aivo/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "dev:web": "EXPO_NO_TELEMETRY=1 expo start --web",
    "dev:ios": "EXPO_NO_TELEMETRY=1 expo start --ios",
    "dev:android": "EXPO_NO_TELEMETRY=1 expo start --android",
    "build": "expo run:ios || expo run:android",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "expo": "~52.0.38",
    "expo-router": "~4.0.17",
    "expo-status-bar": "~2.0.1",
    "react": "19.0.0",
    "react-native": "0.77.1",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.8.1",
    "nativewind": "^4.1.23",
    "lucide-react-native": "^0.469.0",
    "@aivo/shared-types": "workspace:*",
    "@aivo/compute": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.0.0",
    "@types/react-native": "~0.77.0",
    "typescript": "~5.7.3",
    "eslint": "^9.18.0",
    "eslint-config-expo": "^8.0.1"
  }
}
