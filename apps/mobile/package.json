{
  "name": "@aivo/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "dev:web": "EXPO_NO_TELEMETRY=1 expo start --web",
    "dev:ios": "EXPO_NO_TELEMETRY=1 expo start --ios",
    "dev:android": "EXPO_NO_TELEMETRY=1 expo start --android",
    "build": "expo run:ios || expo run:android",
    "build:web": "expo export --platform web",
    "lint": "eslint app --ext .ts,.tsx --fix --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.test.tsx\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@aivo/api-client": "workspace:*",
    "@aivo/body-compute": "workspace:*",
    "@aivo/compute": "workspace:*",
    "@aivo/shared-types": "workspace:*",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "expo": "~52.0.38",
    "expo-auth-session": "^6.1.1",
    "expo-crypto": "~14.0.1",
    "expo-file-system": "^55.0.17",
    "expo-haptics": "~14.0.1",
    "expo-image-picker": "^55.0.19",
    "expo-media-library": "^55.0.15",
    "expo-router": "~4.0.17",
    "expo-secure-store": "^55.0.13",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "~13.0.3",
    "lucide-react-native": "^0.469.0",
    "nativewind": "^4.1.23",
    "react": "19.0.0",
    "react-native": "0.77.1",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "victory-native": "^40.1.2"
  },
  "devDependencies": {
    "@aivo/eslint-config": "workspace:*",
    "@aivo/jest-config": "workspace:*",
    "@babel/core": "^7.26.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "babel-jest": "^30.3.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.6",
    "ts-jest": "^29.4.9",
    "typescript": "~5.7.3"
  }
}
