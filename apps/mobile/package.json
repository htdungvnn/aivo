{
  "name": "@aivo/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "expo": {
    "ios": {
      "deploymentTarget": "16.0"
    }
  },
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "dev:web": "EXPO_NO_TELEMETRY=1 expo start --web",
    "dev:ios": "EXPO_NO_TELEMETRY=1 expo start --ios",
    "dev:android": "EXPO_NO_TELEMETRY=1 expo start --android",
    "build": "pnpm run build:web",
    "build:ios": "expo run:ios",
    "build:android": "expo run:android",
    "build:web": "expo export --platform web",
    "lint": "eslint app --ext .ts,.tsx --fix --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.test.tsx\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@aivo/api-client": "workspace:*",
    "@aivo/body-compute": "workspace:*",
    "@aivo/compute": "workspace:*",
    "@aivo/shared-types": "workspace:*",
    "@expo/metro-runtime": "^6.1.2",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "^5.2.0",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-av": "^16.0.8",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-health": "^0.0.0",
    "expo-image-picker": "~17.0.10",
    "expo-media-library": "~18.2.1",
    "expo-modules-core": "~3.0.0",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.469.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "victory-native": "^40.1.2"
  },
  "devDependencies": {
    "@aivo/eslint-config": "workspace:*",
    "@aivo/jest-config": "workspace:*",
    "@babel/core": "7.29.0",
    "@react-native-community/cli": "^20.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "19.1.17",
    "@types/react-native": "0.73.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "expo-build-properties": "^55.0.13",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "3.4.6",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
