{
  "name": "@aivo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "pnpm copy-wasm && wrangler deploy --dry-run --outdir=dist --assets ./assets",
    "copy-wasm": "mkdir -p assets && cp -f ../../packages/infographic-generator/pkg/infographic_generator_bg.wasm assets/ 2>/dev/null && cp -f ../../packages/aivo-compute/pkg/aivo_compute_bg.wasm assets/ 2>/dev/null || echo 'WASM files not found, skipping copy'",
    "deploy": "wrangler deploy --assets ./assets",
    "lint": "eslint src --ext .ts,.tsx --fix --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.test.tsx\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aivo/compute": "workspace:*",
    "@aivo/db": "workspace:*",
    "@aivo/email-reporter": "workspace:*",
    "@aivo/excel-export": "workspace:*",
    "@aivo/infographic-generator": "workspace:*",
    "@aivo/memory-service": "workspace:*",
    "@aivo/optimizer": "workspace:*",
    "@aivo/shared-types": "workspace:*",
    "@anthropic-ai/sdk": "^0.90.0",
    "@cloudflare/d1": "^1.4.1",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "0.19.10",
    "axios": "^1.15.2",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.14",
    "jose": "^5.10.0",
    "openai": "^4.84.0",
    "resend": "^4.1.0",
    "swagger-jsdoc": "^6.2.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aivo/eslint-config": "workspace:*",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "eslint": "^9.7.0",
    "jest": "^29.7.0",
    "jest-environment-miniflare": "^2.14.4",
    "ts-jest": "^29.2.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.86.0"
  }
}
