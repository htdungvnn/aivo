{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@aivo/shared-types": ["../../packages/shared-types/src"],
      "@aivo/compute": ["../../packages/aivo-compute/pkg"],
      "@aivo/db": ["../../packages/db/src"],
      "@aivo/infographic-generator": ["../../packages/infographic-generator/pkg"],
      "@aivo/api-client": ["../../packages/api-client/src"],
      "@aivo/memory-service": ["../../packages/memory-service/src"],
      "@aivo/optimizer": ["../../packages/optimizer/pkg"]
    },
    "types": ["@cloudflare/workers-types"],
    "baseUrl": "./",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "src/__tests__/**", "**/*.test.ts", "**/*.test.tsx",
    "src/routes/nutrition.ts", "src/routes/form-analyze.ts", "src/routes/live-workout.ts", "src/routes/metabolic.ts",
    "src/services/nutrition/**", "src/services/form-analyzer.ts", "src/services/live-workout.ts"]
}
