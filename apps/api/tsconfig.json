{
  "extends": "@cloudflare/workers-types/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@aivo/shared-types": ["../../packages/shared-types/src"],
      "@aivo/compute": ["../../packages/aivo-compute/pkg"],
      "@aivo/db": ["../../packages/db/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
